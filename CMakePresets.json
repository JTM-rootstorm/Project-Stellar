{
  "version": 2,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 20,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "linux-default",
      "displayName": "Linux default OpenGL build",
      "description": "Default Linux validation build with OpenGL enabled and Metal disabled.",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build-linux",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "STELLAR_ENABLE_VULKAN_BACKEND": "OFF",
        "STELLAR_ENABLE_OPENGL_BACKEND": "ON",
        "STELLAR_ENABLE_METAL": "OFF"
      }
    },
    {
      "name": "linux-vulkan",
      "displayName": "Linux Vulkan build",
      "description": "Linux build with Vulkan enabled and OpenGL temporarily enabled during migration.",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build-linux-vulkan",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "STELLAR_ENABLE_VULKAN_BACKEND": "ON",
        "STELLAR_ENABLE_VULKAN_CONTEXT_TESTS": "ON",
        "STELLAR_ENABLE_OPENGL_BACKEND": "ON",
        "STELLAR_ENABLE_METAL": "OFF"
      }
    },
    {
      "name": "linux-vulkan-only",
      "displayName": "Linux Vulkan-only build",
      "description": "Linux build with Vulkan enabled and OpenGL/GLEW disabled.",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build-linux-vulkan-only",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "STELLAR_ENABLE_VULKAN_BACKEND": "ON",
        "STELLAR_ENABLE_VULKAN_CONTEXT_TESTS": "ON",
        "STELLAR_ENABLE_OPENGL_BACKEND": "OFF",
        "STELLAR_ENABLE_METAL": "OFF"
      }
    },
    {
      "name": "macos-default",
      "displayName": "macOS default OpenGL build",
      "description": "Default macOS validation build with OpenGL enabled and Metal disabled.",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build-macos",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "STELLAR_ENABLE_VULKAN_BACKEND": "OFF",
        "STELLAR_ENABLE_OPENGL_BACKEND": "ON",
        "STELLAR_ENABLE_METAL": "OFF"
      }
    },
    {
      "name": "macos-metal",
      "displayName": "macOS Metal build",
      "description": "macOS build with OpenGL and the Apple-gated Metal backend enabled.",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build-macos-metal",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "STELLAR_ENABLE_VULKAN_BACKEND": "OFF",
        "STELLAR_ENABLE_OPENGL_BACKEND": "ON",
        "STELLAR_ENABLE_METAL": "ON",
        "STELLAR_ENABLE_METAL_CONTEXT_TESTS": "ON"
      }
    },
    {
      "name": "macos-metal-only",
      "displayName": "macOS Metal-only build",
      "description": "macOS build with OpenGL/GLEW disabled and the Metal backend enabled.",
      "generator": "Unix Makefiles",
      "binaryDir": "${sourceDir}/build-macos-metal-only",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "STELLAR_ENABLE_VULKAN_BACKEND": "OFF",
        "STELLAR_ENABLE_OPENGL_BACKEND": "OFF",
        "STELLAR_ENABLE_METAL": "ON",
        "STELLAR_ENABLE_METAL_CONTEXT_TESTS": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "linux-default",
      "configurePreset": "linux-default"
    },
    {
      "name": "linux-vulkan",
      "configurePreset": "linux-vulkan"
    },
    {
      "name": "linux-vulkan-only",
      "configurePreset": "linux-vulkan-only"
    },
    {
      "name": "macos-default",
      "configurePreset": "macos-default"
    },
    {
      "name": "macos-metal",
      "configurePreset": "macos-metal"
    },
    {
      "name": "macos-metal-only",
      "configurePreset": "macos-metal-only"
    }
  ],
  "testPresets": [
    {
      "name": "linux-default",
      "configurePreset": "linux-default",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "linux-vulkan",
      "configurePreset": "linux-vulkan",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "linux-vulkan-only",
      "configurePreset": "linux-vulkan-only",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "macos-default",
      "configurePreset": "macos-default",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "macos-metal",
      "configurePreset": "macos-metal",
      "output": {
        "outputOnFailure": true
      }
    },
    {
      "name": "macos-metal-only",
      "configurePreset": "macos-metal-only",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
